<%- include('partials/header', { title: 'Pagos' }) %>

<div class="max-w-xl mx-auto p-8 rounded-2xl shadow-xl border border-gray-800 bg-gray-900/60 backdrop-blur">

  <h2 class="text-2xl text-cyan-400 font-semibold mb-4">
    Sistema de Pago
  </h2>

  <form id="form" class="space-y-4">

    <input name="tipo" id="tipo" placeholder="Tipo de gasto"
      class="w-full p-3 rounded-xl bg-gray-800 text-white border border-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition">

    <input id="amount" type="number" placeholder="Monto (MXN)"
      class="w-full p-3 rounded-xl bg-gray-800 text-white border border-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition"
      required>

    <select name="metodo" id="metodo"
      class="w-full p-3 rounded-xl bg-gray-800 text-white border border-gray-700 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 outline-none transition">
      <option>Débito</option>
      <option>Crédito</option>
    </select>

    <button id="btn" type="submit"
      class="w-full py-3 rounded-xl text-white font-medium bg-gradient-to-r from-purple-600 to-cyan-500 hover:opacity-90 transition">
      Pagar ahora
    </button>

  </form>

  <!-- STATUS -->
  <div id="status" class="mt-6 text-center text-sm text-gray-400"></div>

</div>

<script src="https://js.stripe.com/v3/"></script>

<script>
const stripe = Stripe("pk_test_51TFFa2L4f7Dhc3FSW8QD3OUZMWCUz6SKMi1kQQMY139CzweJBmiqAlyIT0AN4Al8RFn9aOZDuoGUi2WA6PHgQEN400bUWAdtTw");

const form = document.getElementById('form');
const btn = document.getElementById('btn');
const status = document.getElementById('status');

form.addEventListener('submit', async (e) => {
  e.preventDefault();

  const amount = document.getElementById('amount').value;
  const tipo = document.getElementById('tipo').value;
  const metodo = document.getElementById('metodo').value;

  btn.innerText = "🔄 Procesando...";
  btn.disabled = true;
  status.innerHTML = "Generando sesión segura...";

  try {
    const res = await fetch('/payment/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amount, tipo, metodo })
    });

    const data = await res.json();

    if (!data.id) {
      throw new Error("No se recibió session ID");
    }

    status.innerHTML = "Redirigiendo a Stripe...";

    await stripe.redirectToCheckout({ sessionId: data.id });

  } catch (error) {
    console.error(error);
    status.innerHTML = "⚠️ Error al realizar el pago";
    btn.innerText = "Pagar ahora";
    btn.disabled = false;
  }
});
</script>

<%- include('partials/footer') %>